# Supabase Keys
# The URL of your Supabase project (from Settings -> API)
NEARPRO_SUPABASE_URL=https://your-project-id.supabase.co

# The public anon key (safe to expose in frontend)
NEARPRO_SUPABASE_ANON_KEY=your-anon-key-here

# The private service role key (NEVER expose to frontend, only for local sync script)
NEARPRO_SUPABASE_SERVICE_KEY=your-service-role-key-here

# Local Scraper Database Path (relative to the sync directory)
NEARPRO_DB_PATH=../../.harvest/harvest.db

# Optional Webhook for outreach integration
NEARPRO_N8N_WEBHOOK_URL=http://localhost:5678/webhook/export-trigger
NEARPRO_EXPORT_API_KEY=your-secret-export-key-here
